# Copy to .env and fill in every value.
# docker-compose reads POSTGRES_* (with built-in defaults if unset).

# Database — POSTGRES_* must match what DATABASE_URL points at
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# Prisma connection string, e.g. postgresql://USER:PASSWORD@localhost:5432/DB?schema=public
DATABASE_URL=

# JWT — secret must be >=32 chars (e.g. `openssl rand -hex 32`); expiry like "900", "15m" or "7d".
# Refresh tokens are opaque random strings stored hashed in Postgres — no JWT refresh vars needed.
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=

# WebSocket CORS — leave empty/omit to allow all origins
CORS_ORIGIN=

# Claim-victory windows (milliseconds)
CLAIM_GRACE_MS=60000       # disconnect grace before the opponent may claim a forfeit win
CLAIM_AFK_LIMIT_MS=120000  # per-phase inactivity before the opponent may claim an AFK win
